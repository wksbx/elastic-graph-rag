# =============================================================================
# Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# =============================================================================

# Elasticsearch
ELASTIC_PASSWORD=changeme
ES_HOST=http://localhost:9200

# ---------------------------------------------------------------------------
# Embedding model — choose one provider
# ---------------------------------------------------------------------------

# Option A: Voyage AI
# EMBEDDING_MODEL=voyage
# VOYAGE_API_KEY=your-voyage-api-key
# EMBEDDING_MODEL_NAME=voyage-3.5
# EMBEDDING_DIMENSIONS=1024

# Option B: OpenAI
# EMBEDDING_MODEL=openai
# OPENAI_API_KEY=your-openai-api-key
# EMBEDDING_MODEL_NAME=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# Option C: Self-hosted via Elasticsearch inference API (no external API key needed)
# EMBEDDING_MODEL=elasticsearch
# EMBEDDING_MODEL_NAME=.multilingual-e5-small
# EMBEDDING_DIMENSIONS=384

# ---------------------------------------------------------------------------
# LLM for RAG answer generation — choose one provider
# ---------------------------------------------------------------------------

# Option A: Anthropic (Claude)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key
# LLM_MODEL=claude-sonnet-4-20250514

# Option B: OpenAI (GPT)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# LLM_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Ingestion settings
# ---------------------------------------------------------------------------
CHUNK_SIZE=512           # tokens per chunk
CHUNK_OVERLAP=64         # ~12% overlap
DOCS_PATH=./data/docs    # directory of markdown files
INDEX_NAME=knowledge-base
